@model IEnumerable<MyBudgetApp.Core.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold"><i class="bi bi-tags me-2 text-warning"></i>Categories</h2>
        <p class="text-muted mb-0">Manage your transaction categories</p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Add Category
    </a>
</div>

@if (Model.Any())
{
    <div class="row g-3">
        @foreach (var category in Model)
        {
            <div class="col-md-3 col-sm-4 col-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-3">
                        <div class="rounded-circle mx-auto mb-2" style="width:40px;height:40px;background-color:@category.Color;"></div>
                        <p class="fw-semibold mb-1">@category.Name</p>
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-tags fs-1 d-block mb-3"></i>
        <h5>No categories yet</h5>
        <p><a asp-action="Create">Create your first category</a></p>
    </div>
}
