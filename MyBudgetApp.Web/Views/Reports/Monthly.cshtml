@model IEnumerable<MyBudgetApp.Core.Models.Transaction>
@using MyBudgetApp.Core.Models
@using MyBudgetApp.Core.DTOs
@{
    ViewData["Title"] = $"Report: {ViewBag.MonthName}";
    int year = ViewBag.Year;
    int month = ViewBag.Month;
    decimal totalIncome = ViewBag.TotalIncome ?? 0m;
    decimal totalExpenses = ViewBag.TotalExpenses ?? 0m;
    decimal balance = ViewBag.Balance ?? 0m;
    var categorySummaries = ViewBag.CategorySummaries as IEnumerable<CategorySummaryDto> ?? Enumerable.Empty<CategorySummaryDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold"><i class="bi bi-calendar-month me-2 text-info"></i>@ViewBag.MonthName</h2>
        <p class="text-muted mb-0">Monthly transaction breakdown</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Reports
    </a>
</div>

<!-- Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 bg-success bg-opacity-10">
            <div class="card-body text-center">
                <small class="text-muted d-block">Total Income</small>
                <h4 class="fw-bold text-success">@totalIncome.ToString("C")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-danger bg-opacity-10">
            <div class="card-body text-center">
                <small class="text-muted d-block">Total Expenses</small>
                <h4 class="fw-bold text-danger">@totalExpenses.ToString("C")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 @(balance >= 0 ? "bg-primary" : "bg-warning") bg-opacity-10">
            <div class="card-body text-center">
                <small class="text-muted d-block">Net Balance</small>
                <h4 class="fw-bold @(balance >= 0 ? "text-primary" : "text-warning")">@balance.ToString("C")</h4>
            </div>
        </div>
    </div>
</div>

<!-- Navigation -->
<div class="d-flex justify-content-between mb-4">
    @{
        var prevDate = new DateTime(year, month, 1).AddMonths(-1);
        var nextDate = new DateTime(year, month, 1).AddMonths(1);
        bool canGoNext = nextDate <= DateTime.Today;
    }
    <a asp-action="Monthly" asp-route-year="@prevDate.Year" asp-route-month="@prevDate.Month"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-chevron-left me-1"></i> @prevDate.ToString("MMMM yyyy")
    </a>
    @if (canGoNext)
    {
        <a asp-action="Monthly" asp-route-year="@nextDate.Year" asp-route-month="@nextDate.Month"
           class="btn btn-outline-secondary btn-sm">
            @nextDate.ToString("MMMM yyyy") <i class="bi bi-chevron-right ms-1"></i>
        </a>
    }
</div>

<div class="row g-4">
    <!-- Transactions Table -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">Transactions (@Model.Count())</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Category</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model)
                                {
                                    <tr>
                                        <td class="text-nowrap">@t.Date.ToString("dd MMM")</td>
                                        <td>
                                            @if (t.Category != null)
                                            {
                                                <span class="badge rounded-pill" style="background-color: @t.Category.Color">
                                                    @t.Category.Name
                                                </span>
                                            }
                                        </td>
                                        <td class="text-muted small">@(t.Description ?? "-")</td>
                                        <td class="text-end fw-semibold @(t.Type == TransactionType.Income ? "text-success" : "text-danger")">
                                            @(t.Type == TransactionType.Income ? "+" : "-")@t.Amount.ToString("C")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No transactions this month.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Category Breakdown -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">Category Breakdown</h5>
            </div>
            <div class="card-body">
                @if (categorySummaries.Any())
                {
                    foreach (var cat in categorySummaries)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle me-2" style="width:12px;height:12px;background-color:@cat.Color;"></div>
                                <small>@cat.CategoryName</small>
                            </div>
                            <small class="fw-semibold">@cat.TotalAmount.ToString("C")</small>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted text-center">No data</p>
                }
            </div>
        </div>
    </div>
</div>
