@model IEnumerable<MyBudgetApp.Core.DTOs.MonthlySummaryDto>
@{
    ViewData["Title"] = "Monthly Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold"><i class="bi bi-bar-chart me-2 text-info"></i>Monthly Reports</h2>
        <p class="text-muted mb-0">Financial summaries broken down by month</p>
    </div>
</div>

@if (Model.Any())
{
    <!-- Chart -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent">
            <h5 class="mb-0">Income vs Expenses (Last 12 Months)</h5>
        </div>
        <div class="card-body">
            <canvas id="reportsChart" height="80"></canvas>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Month</th>
                            <th class="text-end text-success">Income</th>
                            <th class="text-end text-danger">Expenses</th>
                            <th class="text-end">Balance</th>
                            <th class="text-center">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var month in Model.OrderByDescending(m => m.Year).ThenByDescending(m => m.Month))
                        {
                            <tr>
                                <td class="fw-semibold">@month.MonthName</td>
                                <td class="text-end text-success">@month.TotalIncome.ToString("C")</td>
                                <td class="text-end text-danger">@month.TotalExpenses.ToString("C")</td>
                                <td class="text-end fw-bold @(month.Balance >= 0 ? "text-primary" : "text-warning")">
                                    @month.Balance.ToString("C")
                                </td>
                                <td class="text-center">
                                    <a asp-action="Monthly" asp-route-year="@month.Year" asp-route-month="@month.Month"
                                       class="btn btn-outline-info btn-sm">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-bar-chart fs-1 d-block mb-3"></i>
        <h5>No report data yet</h5>
        <p>Start <a asp-controller="Transactions" asp-action="Create">adding transactions</a> to see reports.</p>
    </div>
}

@section Scripts {
    <script>
        const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(m => new {
            label = m.MonthName,
            income = m.TotalIncome,
            expenses = m.TotalExpenses
        }).OrderBy(m => m.label)));

        if (data.length > 0) {
            new Chart(document.getElementById('reportsChart'), {
                type: 'line',
                data: {
                    labels: data.map(m => m.label),
                    datasets: [
                        {
                            label: 'Income',
                            data: data.map(m => m.income),
                            borderColor: 'rgba(40, 167, 69, 1)',
                            backgroundColor: 'rgba(40, 167, 69, 0.1)',
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Expenses',
                            data: data.map(m => m.expenses),
                            borderColor: 'rgba(220, 53, 69, 1)',
                            backgroundColor: 'rgba(220, 53, 69, 0.1)',
                            fill: true,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top' } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        }
    </script>
}
