@model IEnumerable<MyBudgetApp.Core.Models.Transaction>
@using MyBudgetApp.Core.Models
@using MyBudgetApp.Core.DTOs
@{
    ViewData["Title"] = "Transactions";
    var filter = ViewBag.Filter as TransactionFilterDto ?? new TransactionFilterDto();
    decimal totalIncome = ViewBag.TotalIncome ?? 0m;
    decimal totalExpenses = ViewBag.TotalExpenses ?? 0m;
    decimal balance = ViewBag.Balance ?? 0m;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold"><i class="bi bi-list-ul me-2 text-primary"></i>Transactions</h2>
        <p class="text-muted mb-0">Manage your income and expense records</p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Add Transaction
    </a>
</div>

<!-- Summary Bar -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 bg-success bg-opacity-10">
            <div class="card-body py-2 text-center">
                <small class="text-muted">Income</small>
                <div class="fw-bold text-success">@totalIncome.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 bg-danger bg-opacity-10">
            <div class="card-body py-2 text-center">
                <small class="text-muted">Expenses</small>
                <div class="fw-bold text-danger">@totalExpenses.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 @(balance >= 0 ? "bg-primary" : "bg-warning") bg-opacity-10">
            <div class="card-body py-2 text-center">
                <small class="text-muted">Balance</small>
                <div class="fw-bold @(balance >= 0 ? "text-primary" : "text-warning")">@balance.ToString("C")</div>
            </div>
        </div>
    </div>
</div>

<!-- Filter Form -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent">
        <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter Transactions</h6>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small">Start Date</label>
                    <input type="date" name="StartDate" class="form-control form-control-sm"
                           value="@(filter.StartDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">End Date</label>
                    <input type="date" name="EndDate" class="form-control form-control-sm"
                           value="@(filter.EndDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Category</label>
                    <select name="CategoryId" asp-items="ViewBag.Categories" class="form-select form-select-sm">
                        <option value="">All Categories</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Type</label>
                    <select name="Type" class="form-select form-select-sm">
                        <option value="">All Types</option>
                        <option value="Income" selected="@(filter.Type == "Income")">Income</option>
                        <option value="Expense" selected="@(filter.Type == "Expense")">Expense</option>
                    </select>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i> Apply Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-2">
                    <i class="bi bi-x-circle me-1"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Transaction Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th class="text-end">Amount</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@t.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (t.Category != null)
                                    {
                                        <span class="badge rounded-pill" style="background-color: @t.Category.Color">
                                            @t.Category.Name
                                        </span>
                                    }
                                </td>
                                <td class="text-muted small">@(t.Description ?? "-")</td>
                                <td>
                                    @if (t.Type == TransactionType.Income)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            <i class="bi bi-arrow-down me-1"></i>Income
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                            <i class="bi bi-arrow-up me-1"></i>Expense
                                        </span>
                                    }
                                </td>
                                <td class="text-end fw-semibold @(t.Type == TransactionType.Income ? "text-success" : "text-danger")">
                                    @(t.Type == TransactionType.Income ? "+" : "-")@t.Amount.ToString("C")
                                </td>
                                <td class="text-center text-nowrap">
                                    <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-outline-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-outline-danger btn-sm ms-1">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                <h5>No transactions found</h5>
                <p>Try adjusting the filters or <a asp-action="Create">add a new transaction</a>.</p>
            </div>
        }
    </div>
</div>
