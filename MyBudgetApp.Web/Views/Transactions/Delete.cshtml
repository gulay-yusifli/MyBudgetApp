@model MyBudgetApp.Core.Models.Transaction
@using MyBudgetApp.Core.Models
@{
    ViewData["Title"] = "Delete Transaction";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Delete Transaction</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Are you sure you want to delete this transaction? This action cannot be undone.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Amount</dt>
                    <dd class="col-sm-8 fw-bold @(Model.Type == TransactionType.Income ? "text-success" : "text-danger")">
                        @Model.Amount.ToString("C")
                    </dd>

                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("dd MMMM yyyy")</dd>

                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">
                        @if (Model.Type == TransactionType.Income)
                        {
                            <span class="badge bg-success">Income</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Expense</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">
                        @if (Model.Category != null)
                        {
                            <span class="badge rounded-pill" style="background-color: @Model.Category.Color">@Model.Category.Name</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "-")</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
